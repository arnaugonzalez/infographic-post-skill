# === Infographic Skill — Environment Configuration ===
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Core generation (matplotlib) requires NO env vars.
# These are only needed for "pretty mode" (Gemini AI generation).

# --- Option A: Google AI Studio (quickest setup) ---
# Get your key at: https://aistudio.google.com/apikey
INFG_API_KEY=

# --- Option B: Google Cloud Vertex AI (recommended for production) ---
# Requires a GCP project with Vertex AI API enabled.
# Auth: uses Application Default Credentials (gcloud auth application-default login)
INFG_VERTEX_PROJECT=
INFG_VERTEX_LOCATION=us-central1

# --- Display ---
# Set for headless/CI environments (no GUI):
# MPLBACKEND=Agg
