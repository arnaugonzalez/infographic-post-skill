# === Infographic Skill — Environment Configuration ===
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Core generation (matplotlib) requires NO env vars.
# These are only needed for "pretty mode" (Gemini AI generation).

# --- Option A: Google AI Studio (recommended for the default max-quality image model) ---
# Get your key at: https://aistudio.google.com/apikey
INFG_API_KEY=

# --- Option B: Google Cloud Vertex AI (optional) ---
# Requires a GCP project with Vertex AI API enabled.
# Auth: uses Application Default Credentials (gcloud auth application-default login)
INFG_VERTEX_PROJECT=
INFG_VERTEX_LOCATION=us-central1

# --- Option C: Multi-Provider LLM Support (v1.0) ---
# Choose which LLM provider handles text/HTML generation.
# Default: gemini (uses INFG_API_KEY or Vertex credentials above).
INFG_LLM_PROVIDER=

# Override the default LLM text model for LinkedIn post generation.
# Default: google/gemini-2.0-flash-001 (best language fidelity, fast, low cost)
#
# Model quality tiers (for infographic and post generation):
#   Tier 1 (best):  anthropic/claude-sonnet-4-20250514, google/gemini-2.5-pro, openai/gpt-4o
#   Tier 2 (good):  google/gemini-2.0-flash-001, anthropic/claude-haiku-4-5, deepseek/deepseek-chat-v3-0324
#   Tier 3 (low):   meta-llama/llama-3.3-70b-instruct, microsoft/phi-4, mistralai/mistral-7b-instruct
#
# Avoid: microsoft/phi-4 (16k ctx too small), mistralai/mistral-small-3.1-24b-instruct (slow)
INFG_LLM_MODEL=google/gemini-2.0-flash-001

# Generic LLM API key — used when no provider-specific key is set.
INFG_LLM_API_KEY=

# Dedicated OpenRouter API key (takes precedence over INFG_LLM_API_KEY when provider=openrouter).
# Get your key at: https://openrouter.ai/keys
INFG_OPENROUTER_API_KEY=

# Override the default image model (gemini-3.1-flash-image-preview).
# Only applies when --model flag is not explicitly passed on the CLI.
INFG_IMAGE_MODEL=

# --- Display ---
# Set for headless/CI environments (no GUI):
# MPLBACKEND=Agg
